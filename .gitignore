#   NOT in this repo — this is defense in depth in case one gets copied in.)
# ============================================================
*private*.xml
onceware-private.xml
keys-ledger.json
keys-ledger.jsonl
revoked-keys.txt
*.oncelic
admin.html
licensing.ps1

